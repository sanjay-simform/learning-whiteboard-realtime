{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npx tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:generate -d src/db/data-source.ts",
    "migration:create": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:create -d src/db/data-source.ts",
    "migration:run": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:run -d src/db/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli migration:revert -d src/db/data-source.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^8.5.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/node": "^25.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
